# ============================================
# 应用配置
# ============================================
NODE_ENV=development
PORT=8000
APP_URL=http://localhost:8000
APP_NAME=城市智慧应急协同调度平台
FRONTEND_URL=http://localhost:3000

# ============================================
# 数据库配置
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=emergency_dispatch
DB_USER=root
# 请根据您的MySQL配置设置密码
# 如果MySQL root用户无密码，保持为空
# 如果MySQL root用户有密码，请填写实际密码
DB_PASSWORD=password

# 数据库字符集和时区
DB_CHARSET=utf8mb4
DB_TIMEZONE=+08:00

# ============================================
# JWT配置
# ============================================
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_refresh_token_secret_change_this_in_production
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# Redis配置
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# WebSocket配置
# ============================================
WS_CORS_ORIGIN=http://localhost:3000
WS_PING_TIMEOUT=5000
WS_PING_INTERVAL=30000
WS_HEARTBEAT_INTERVAL=25000
WS_HEARTBEAT_TIMEOUT=60000

# ============================================
# 外部服务配置
# ============================================
# OpenStreetMap瓦片服务
OSM_TILE_URL=https://{a-c}.tile.openstreetmap.org/{z}/{x}/{y}.png

# 天地图服务（需要申请密钥）
TIANDITU_KEY=
TIANDITU_VECTOR_URL=
TIANDITU_IMAGE_URL=

# GraphHopper路由服务（需要本地部署）
GRAPPHOPPER_URL=http://localhost:8989
GRAPPHOPPER_DEFAULT_PROFILE=car

# Nominatim地理编码服务
NOMINATIM_URL=https://nominatim.openstreetmap.org

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=info
LOG_FILE_PATH=./logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# ============================================
# 地图配置
# ============================================
MAP_DEFAULT_CENTER_LNG=116.404
MAP_DEFAULT_CENTER_LAT=39.915
MAP_DEFAULT_ZOOM=12
MAP_MIN_ZOOM=3
MAP_MAX_ZOOM=18
MAP_DEFAULT_CRS=EPSG:3857
