# ============================================
# 城市智慧应急协同调度平台 - 环境变量配置
# ============================================

# ==================
# 应用配置 / Application
# ==================
NODE_ENV=development
PORT=3001
APP_NAME=城市智慧应急协同调度平台
APP_URL=http://localhost:3001

# ==================
# 前端配置 / Frontend
# ==================
FRONTEND_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:3001

# ==================
# 数据库配置 / Database
# ==================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=emergency_dispatch
DB_USER=root
DB_PASSWORD=password
DB_CHARSET=utf8mb4
DB_TIMEZONE=+08:00

# ==================
# Redis配置 / Redis
# ==================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==================
# JWT配置 / JWT
# ==================
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_refresh_token_secret
JWT_REFRESH_EXPIRES_IN=7d

# ==================
# WebSocket配置 / WebSocket
# ==================
WS_PORT=3001
WS_PATH=/socket.io/
WS_CORS_ORIGIN=http://localhost:3000

# ==================
# 文件上传配置 / File Upload
# ==================
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,application/pdf
UPLOAD_PATH=./uploads

# ==================
# 外部服务配置 / External Services
# ==================

# OpenStreetMap瓦片服务
OSM_TILE_URL=https://{a-c}.tile.openstreetmap.org/{z}/{x}/{y}.png

# 天地图配置（需申请Key）
TIANDITU_KEY=your_tianditu_key_here
TIANDITU_VECTOR_URL=https://t0.tianditu.gov.cn/vec_w/wmts
TIANDITU_IMAGE_URL=https://t0.tianditu.gov.cn/img_w/wmts

# GraphHopper路径规划服务
GRAPPHOPPER_URL=http://localhost:8989
GRAPPHOPPER_DEFAULT_PROFILE=car

# Nominatim地理编码
NOMINATIM_URL=https://nominatim.openstreetmap.org

# ==================
# 日志配置 / Logging
# ==================
LOG_LEVEL=debug
LOG_FILE_PATH=./logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# ==================
# 限流配置 / Rate Limiting
# ==================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==================
# 告警配置 / Alert
# ==================
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_SMTP_HOST=smtp.example.com
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_USER=noreply@example.com
ALERT_EMAIL_PASS=your_email_password

ALERT_SMS_ENABLED=false
ALERT_SMS_PROVIDER=aliyun
ALERT_SMS_ACCESS_KEY=your_access_key
ALERT_SMS_SECRET_KEY=your_secret_key

# ==================
# 性能配置 / Performance
# ==================
CLUSTER_MODE=false
CLUSTER_INSTANCES=max

# 缓存配置
CACHE_TTL=3600
CACHE_MAX_KEYS=10000

# ==================
# 安全配置 / Security
# ==================
BCRYPT_ROUNDS=10
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:3000
HELMET_ENABLED=true

# ==================
# 地图配置 / Map Configuration
# ==================
MAP_DEFAULT_CENTER_LNG=116.404
MAP_DEFAULT_CENTER_LAT=39.915
MAP_DEFAULT_ZOOM=12
MAP_MIN_ZOOM=3
MAP_MAX_ZOOM=18

# 坐标系配置
MAP_DEFAULT_CRS=EPSG:3857
MAP_PROJECTION_DEFINITIONS={"EPSG:4490":"+proj=longlat +ellps=GRS80 +no_defs"}

# ==================
# WebSocket心跳配置 / WebSocket Heartbeat
# ==================
WS_HEARTBEAT_INTERVAL=25000
WS_HEARTBEAT_TIMEOUT=60000
WS_PING_INTERVAL=30000
WS_PING_TIMEOUT=5000

# ==================
# 轨迹回放配置 / Trajectory Playback
# ==================
TRAJECTORY_INTERPOLATION_ENABLED=true
TRAJECTORY_TARGET_FPS=60
TRAJECTORY_MAX_POINTS=100000
TRAJECTORY_CACHE_SIZE=1000
